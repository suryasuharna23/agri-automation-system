{
  "expo": {
    "name": "Agri Automation",
    "slug": "agri-automation",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.agriautomation.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan Agri menggunakan kamera untuk mengambil foto tanaman dan hasil panen."
        }
      ],
      "expo-secure-store",
      "expo-font"
    ]
  }
}
