# Google Gemini API key — required for LLM insights (disease, grading, sensor)
# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Dev/demo only. When true, unavailable grading/LLM capabilities may return
# clearly marked demo_fallback responses instead of 503 errors.
ENABLE_DEMO_AI_FALLBACK=false
